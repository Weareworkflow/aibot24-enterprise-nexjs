
{
  "entities": {
    "AIAgent": {
      "title": "AI Agent",
      "description": "Configuración técnica, métricas operativas y propiedad de un agente de IA de chat.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tenantId": { "type": "string", "description": "ID del propietario o empresa creadora (member_id de Bitrix)." },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["text"] },
        "role": { "type": "string" },
        "company": { "type": "string" },
        "objective": { "type": "string" },
        "tone": { "type": "string" },
        "knowledge": { "type": "string" },
        "color": { "type": "string" },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "integrations": {
          "type": "object",
          "additionalProperties": { "type": "boolean" }
        },
        "metrics": {
          "type": "object",
          "properties": {
            "usageCount": { "type": "number" },
            "performanceRating": { "type": "number" },
            "totalInteractionMetric": { "type": "number", "description": "Total de mensajes procesados." },
            "latency": { "type": "string" },
            "tokens": { "type": "string" },
            "transfers": { "type": "number" },
            "abandoned": { "type": "number" }
          }
        }
      },
      "required": ["tenantId", "name", "type", "role", "company", "objective", "tone", "knowledge"]
    },
    "BitrixInstallation": {
      "title": "Bitrix Installation",
      "description": "Registro de vinculación exitosa de un portal Bitrix24.",
      "type": "object",
      "properties": {
        "memberId": { "type": "string" },
        "domain": { "type": "string" },
        "accessToken": { "type": "string" },
        "refreshToken": { "type": "string" },
        "expiresIn": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "suspended"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["memberId", "domain", "status", "createdAt"]
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/agents/{agentId}": {
      "schema": { "$ref": "#/entities/AIAgent" },
      "description": "Repositorio central de agentes de chat inteligentes."
    },
    "/installations/{memberId}": {
      "schema": { "$ref": "#/entities/BitrixInstallation" },
      "description": "Registro de portales que han instalado la aplicación."
    }
  }
}
