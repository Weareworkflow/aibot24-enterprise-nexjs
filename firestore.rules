rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Permitir lectura y escritura en la colección de agentes solo a usuarios autenticados
    match /agents/{agentId} {
      allow read, write: if request.auth != null;
    }
    
    // Denegar cualquier otro acceso por defecto para mantener la seguridad
    match /{document=**} {
      allow read, write: if false;
    }
  }
}