rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Permitir acceso público total para la integración embebida (Iframe)
    // El aislamiento de datos se maneja a nivel de aplicación mediante el tenantId (member_id de Bitrix)
    match /agents/{agentId} {
      allow read, write: if true;
    }
    
    // Permitir el registro y verificación de instalaciones de portales Bitrix24
    match /installations/{memberId} {
      allow read, write: if true;
    }
    
    // Configuración global de secretos (Bitrix, etc)
    match /config-secrets/{document} {
      allow read: if true; // Permitir lectura a la aplicación
      allow write: if false; // Solo escritura manual o admin
    }
    
    // Bloquear el acceso al resto de las colecciones por seguridad
    match /{document=**} {
      allow read, write: if true;
    }
  }
}